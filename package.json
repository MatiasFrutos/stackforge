{
  "name": "stackforge",
  "version": "1.0.0",
  "description": "IDE visual, moderno e interactivo para programar en Forth con visualizacion de pila en tiempo real.",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "author": {
    "name": "ZERNYX Tech Studio",
    "url": "https://www.zernyxtechstudio.xyz/"
  },
  "license": "MIT",
  "keywords": [
    "forth",
    "ide",
    "visual-programming",
    "stack",
    "interpreter",
    "react",
    "vite",
    "education",
    "embedded",
    "iot"
  ],
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",

    "electron": "wait-on http://localhost:5173 && electron .",
    "dev:desktop": "concurrently \"npm run dev\" \"npm run electron\"",

    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:exe": "npm run build && electron-builder --win nsis",
    "desktop:portable": "npm run build && electron-builder --win portable",
    "desktop:all": "npm run build && electron-builder --win nsis portable",

    "test": "vitest run",
    "test:watch": "vitest",

    "clean": "node -e \"const fs=require('fs'); ['dist','coverage','release','node_modules/.vite'].forEach(p=>fs.rmSync(p,{recursive:true,force:true})); console.log('Limpieza completada');\"",
    "reinstall": "npm run clean && npm install"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/language": "^6.11.3",
    "@codemirror/lint": "^6.8.5",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.4",
    "@vitejs/plugin-react": "^5.1.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.2.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "vitest": "^4.0.14",
    "wait-on": "^9.0.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "build": {
    "appId": "com.zernyx.stackforge",
    "productName": "StackForge",
    "copyright": "Copyright © 2026 ZERNYX Tech Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico",
      "artifactName": "${productName}-${version}-${arch}-${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StackForge",
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico"
    }
  }
}